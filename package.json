{
  "name": "sortition-iteration-1",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "license": "GPL-3.0-or-later",
  "description": "Browser-native sortition tool (Iteration 1)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @sortition/web dev",
    "tech-manifest": "tsx scripts/build-tech-manifest.ts",
    "prebuild": "pnpm tech-manifest && git diff --exit-code -- apps/web/src/generated/tech-manifest.ts || (echo '[ERROR] tech-manifest.ts is out of date. Run: pnpm tech-manifest && commit the result.' && exit 1)",
    "build": "pnpm --filter @sortition/web build",
    "test": "pnpm --filter @sortition/web test",
    "test:e2e": "pnpm --filter @sortition/web test:e2e",
    "lint": "pnpm --filter @sortition/web lint",
    "typecheck": "pnpm --filter @sortition/web typecheck"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "5.6.3"
  }
}
