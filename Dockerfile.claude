# Dockerfile.claude — Browser-native Sortition Prototype (Iteration 1)
#
# Supports the three engines defined in the plan:
#   - Engine A: TS/Vite/SolidJS + highs-js (browser, Maximin)
#   - Engine B: Pyodide + sortition-algorithms (browser, Maximin via WASM)
#   - Reference C: native Python + sortition-algorithms + highspy (CLI, Maximin)
#
# Plus Playwright (Chromium + Firefox) for the browser benchmark harness.
# WebKit intentionally excluded — iOS/Safari is out of scope per sortition-tool/06-review-consolidation.md P0-3.
# Gurobi intentionally excluded — license handled separately; Reference D (Leximin) is opt-in at workspace level.

FROM ghcr.io/flomotlik/claude-code:latest

USER root

# --- System libraries ---------------------------------------------------------
# Playwright browsers (Chromium + Firefox) need these runtime libs on Debian bookworm.
# BLAS/LAPACK help cvxpy/clarabel/highspy use optimized kernels instead of NumPy fallbacks.
# build-essential + gfortran are kept so any source-only wheel can still build.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      libnss3 libnspr4 libdbus-1-3 libatk1.0-0 libatk-bridge2.0-0 \
      libcups2 libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 \
      libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 libcairo2 \
      libasound2 libatspi2.0-0 \
      libdbus-glib-1-2 libxt6 \
      libopenblas0 liblapack3 \
      build-essential gfortran pkg-config && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# --- pnpm via corepack --------------------------------------------------------
# Pinned for reproducibility. corepack is bundled with Node 20 in the base image.
RUN corepack enable && corepack prepare pnpm@9.12.3 --activate

# --- Python 3.12 venv with the scientific sortition stack ---------------------
# uv is already installed in the base image. We manage Python 3.12 via uv to keep
# version parity with Pyodide 0.29.x (which ships Python 3.12). The venv is shared
# across workspaces so repeated container starts don't reinstall the stack.
ENV SORTITION_VENV=/opt/sortition-venv
ENV PATH=${SORTITION_VENV}/bin:${PATH}

RUN uv python install 3.12 && \
    uv venv --python 3.12 ${SORTITION_VENV} && \
    uv pip install --python ${SORTITION_VENV}/bin/python \
      "sortition-algorithms" \
      "highspy>=1.11" \
      "cvxpy>=1.6" \
      "numpy>=2.0" \
      "scipy>=1.14" \
      "mip>=1.17" \
      "clarabel>=0.9" \
      "pandas>=2.2" \
      "matplotlib>=3.9" \
      "jupyter" \
      "pytest" \
      "pytest-cov" \
      "hypothesis" \
      "rich>=13" \
      "click>=8" \
      "typer>=0.12" \
      "tomli_w>=1.0"

# --- Playwright CLI + browsers -----------------------------------------------
# Browsers land under /opt so they survive workspace wipes and are shared.
# Only Chromium + Firefox — WebKit is deliberately not installed.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN npm install -g playwright@1.49.1 && \
    playwright install chromium firefox && \
    npm cache clean --force

# --- Build-time sanity check --------------------------------------------------
# Fails the image build immediately if any load-bearing tool is missing or broken.
RUN node --version && \
    pnpm --version && \
    python --version && \
    python -c "import sortition_algorithms, highspy, cvxpy, numpy, scipy, mip, clarabel, pandas, matplotlib, hypothesis; print('py-deps ok')" && \
    playwright --version

WORKDIR /root/workspace
